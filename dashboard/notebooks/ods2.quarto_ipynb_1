      "source": [
        "#| label: fig_venn_malnutricion\n",
        "#| output: false\n",
        "\n",
        "I2n22 = pd.read_csv(f\"{path}/2n.2.2_sh_es.csv\", usecols=[1, 2])\n",
        "I2n22.rename(columns={\"Grupos_de_Población|Nacional\": \"Carencia alimentación nutritiva\"}, inplace=True)\n",
        "Porcentaje_alim_nutrit_nacional = I2n22[\"Carencia alimentación nutritiva\"].describe().iloc[1].astype(\"float64\").item()\n",
        "\n",
        "I2222 = pd.read_csv(f\"{path}/2.2.2(2)_sh_es.csv\", usecols=[2, 3, 4])\n",
        "I2222.rename(columns={\"tam_loc_sexo|Nacional\": \"Sobrepeso y Obesidad\", \"Periodo\": \"Año\"}, inplace=True)\n",
        "I2222[\"Entidad_federativa\"] = I2222[\"Entidad_federativa\"].str.replace(\"_\", \" \")\n",
        "I2222_sinND = I2222[~I2222.astype(str).apply(lambda x: x.str.contains(\"ND\")).any(axis=1)].copy().reset_index(drop=True)\n",
        "I2222_nac = I2222_sinND.query(\"Entidad_federativa == 'Estados Unidos Mexicanos'\").reset_index(drop=True).drop(columns=[\"Entidad_federativa\"])\n",
        "\n",
        "I2221 = pd.read_csv(f\"{path}/2.2.2(1)_sh_es.csv\", usecols=[2, 3, 4])\n",
        "I2221.rename(columns={\"tam_loc_sexo|Nacional\": \"Emaciación\", \"Periodo\": \"Año\"}, inplace=True)\n",
        "I2221[\"Entidad_federativa\"] = I2221[\"Entidad_federativa\"].str.replace(\"_\", \" \")\n",
        "I2221_sinND = I2221[~I2221.astype(str).apply(lambda x: x.str.contains(\"ND\")).any(axis=1)].copy().reset_index(drop=True)\n",
        "I2221_nac = I2221_sinND.query(\"Entidad_federativa == 'Estados Unidos Mexicanos'\").reset_index(drop=True).drop(columns=[\"Entidad_federativa\"])\n",
        "\n",
        "I222 = pd.read_csv(f\"{path}/2.2.2_sh_es.csv\", usecols=[2, 3, 4])\n",
        "I222.rename(columns={\"tam_loc_sexo|Nacional\": \"Malnutrición\", \"Periodo\": \"Año\"}, inplace=True)\n",
        "I222[\"Entidad_federativa\"] = I222[\"Entidad_federativa\"].str.replace(\"_\", \" \")\n",
        "I222_sinND = I222[~I222.astype(str).apply(lambda x: x.str.contains(\"ND\")).any(axis=1)].copy().reset_index(drop=True)\n",
        "I222_nac = I222_sinND.query(\"Entidad_federativa == 'Estados Unidos Mexicanos'\").reset_index(drop=True).drop(columns=[\"Entidad_federativa\"])\n",
        "\n",
        "merged = pd.merge(I2221_nac, I2222_nac, on=\"Año\").merge(I222_nac, on=\"Año\")\n",
        "merged[\"Sobrepeso y Obesidad\"] = pd.to_numeric(merged[\"Sobrepeso y Obesidad\"], errors=\"coerce\")\n",
        "merged[\"Emaciación\"] = pd.to_numeric(merged[\"Emaciación\"], errors=\"coerce\")\n",
        "merged[\"Malnutrición\"] = pd.to_numeric(merged[\"Malnutrición\"], errors=\"coerce\")\n",
        "\n",
        "Sobrepeso_2023    = merged.query(\"Año == 2023\")[\"Sobrepeso y Obesidad\"].item()\n",
        "Emaciacion_2023   = merged.query(\"Año == 2023\")[\"Emaciación\"].item()\n",
        "Malnutricion_2023 = merged.query(\"Año == 2023\")[\"Malnutrición\"].item()\n",
        "Desnutricion_2023 = Malnutricion_2023 - Emaciacion_2023 - Sobrepeso_2023\n",
        "\n",
        "fig_venn = go.Figure()\n",
        "\n",
        "fig_venn.add_shape(\n",
        "    type=\"circle\", xref=\"x\", yref=\"y\",\n",
        "    x0=0.0, y0=0.0, x1=8.0, y1=8.0,\n",
        "    fillcolor=\"rgba(217, 174, 97, 0.18)\",\n",
        "    line=dict(color=\"rgba(160, 110, 35, 1)\", width=3)\n",
        ")\n",
        "fig_venn.add_shape(\n",
        "    type=\"circle\", xref=\"x\", yref=\"y\",\n",
        "    x0=1.2, y0=2.0, x1=3.7, y1=4.5,\n",
        "    fillcolor=\"rgba(250, 120, 150, 0.28)\",\n",
        "    line=dict(color=\"rgba(200, 120, 150, 1)\", width=3)\n",
        ")\n",
        "fig_venn.add_shape(\n",
        "    type=\"circle\", xref=\"x\", yref=\"y\",\n",
        "    x0=4.3, y0=2.0, x1=6.8, y1=4.5,\n",
        "    fillcolor=\"rgba(209, 70, 47, 0.25)\",\n",
        "    line=dict(color=\"rgba(209, 70, 47, 1)\", width=3)\n",
        ")\n",
        "\n",
        "fig_venn.add_annotation(x=4.0, y=7.3, text=\"<b>Malnutrición</b>\", showarrow=False,\n",
        "    font=dict(size=20, color=\"rgba(120, 80, 20, 1)\"))\n",
        "fig_venn.add_annotation(x=2.45, y=3.25, text=\"<b>Emaciación</b>\", showarrow=False,\n",
        "    font=dict(size=14, color=\"rgba(200, 120, 150, 1)\"))\n",
        "fig_venn.add_annotation(x=5.55, y=3.25, text=\"<b>Sobrepeso /<br>obesidad</b>\", showarrow=False,\n",
        "    font=dict(size=14, color=\"rgba(160, 40, 30, 1)\"))\n",
        "fig_venn.add_annotation(x=4.0, y=1.15,\n",
        "    text=f\"<b>Desnutrición</b><br><span style='font-size:11px'>Malnutrición sin emaciación<br>ni sobrepeso/obesidad</span>\",\n",
        "    showarrow=False, align=\"center\", font=dict(size=14, color=\"black\"))\n",
        "\n",
        "fig_venn.update_layout(\n",
        "    title=dict(text=\"Malnutrición y sus formas principales\", x=0.5,\n",
        "               font=dict(size=15, color=\"#3a1616\")),\n",
        "    xaxis=dict(showgrid=False, zeroline=False, showticklabels=False, range=[-0.5, 8.5]),\n",
        "    yaxis=dict(showgrid=False, zeroline=False, showticklabels=False, range=[-0.5, 8.5]),\n",
        "    plot_bgcolor=\"rgba(243, 228, 228, 0.35)\",\n",
        "    paper_bgcolor=\"rgba(0,0,0,0)\",\n",
        "    margin=dict(t=50, b=10, l=10, r=10),\n",
        ")"
      ],
      "id": "fig_venn_malnutricion",
      "execution_count": null,
      "outputs": []
    },
