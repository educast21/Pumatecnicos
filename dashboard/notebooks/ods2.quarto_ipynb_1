      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: datos_212a\n",
        "#| output: false\n",
        "\n",
        "ruta_csv = f\"{path}/2.1.2.a_sh_es.csv\"\n",
        "I212a = pd.read_csv(ruta_csv, usecols=[0, 2, 3])\n",
        "I212a.rename(columns={\n",
        "    \"Proporción_de_la_población_con_inseguridad_alimentaria_moderada_o_severa,_por_desglose_geográfico_(Entidad_federativa)\": \"Porcentaje\",\n",
        "    \"Desglose\": \"Estado\",\n",
        "    \"Periodo\": \"Año\"\n",
        "}, inplace=True)\n",
        "I212a = I212a[I212a[\"Estado\"] != \"Estados Unidos Mexicanos\"].copy()\n",
        "I212a = I212a.reset_index(drop=True)\n",
        "\n",
        "reemplazos_entidad = {\n",
        "    \"Coahuila de Zaragoza\": \"Coahuila\",\n",
        "    \"Michoacán de Ocampo\": \"Michoacán\",\n",
        "    \"Veracruz de Ignacio de la Llave\": \"Veracruz\"\n",
        "}\n",
        "I212a[\"Estado\"] = I212a[\"Estado\"].replace(reemplazos_entidad)\n",
        "\n",
        "for i in range(len(I212a)):\n",
        "    valor = I212a[\"Porcentaje\"].iloc[i]\n",
        "    if valor <= 14:\n",
        "        I212a.loc[i, \"Severidad\"] = \"De 0 a 1 de cada 10 personas\"\n",
        "    elif valor <= 34:\n",
        "        I212a.loc[i, \"Severidad\"] = \"De 2 a 3 de cada 10 personas\"\n",
        "    else:\n",
        "        I212a.loc[i, \"Severidad\"] = \"Más de 3 de cada 10 personas\""
      ],
      "id": "datos_212a",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig_mapa_estados\n",
        "#| output: false\n",
        "\n",
        "repo_url = \"https://raw.githubusercontent.com/angelnmara/geojson/master/mexicoHigh.json\"\n",
        "mx_states_geojson = requests.get(repo_url).json()\n",
        "\n",
        "colores_sev = {\n",
        "    \"De 0 a 1 de cada 10 personas\":    \"#87aa16\",\n",
        "    \"De 2 a 3 de cada 10 personas\":    \"#efd720\",\n",
        "    \"Más de 3 de cada 10 personas\":    \"#d14e39\",\n",
        "}\n",
        "\n",
        "I212a[\"Año\"] = I212a[\"Año\"].astype(str)\n",
        "I212a = I212a.sort_values(\"Año\")\n",
        "\n",
        "fig_mapa_estados = px.choropleth(\n",
        "    I212a,\n",
        "    geojson=mx_states_geojson,\n",
        "    locations=\"Estado\",\n",
        "    featureidkey=\"properties.name\",\n",
        "    color=\"Severidad\",\n",
        "    color_discrete_map=colores_sev,\n",
        "    animation_frame=\"Año\",\n",
        "    hover_name=\"Estado\",\n",
        "    hover_data={\"Porcentaje\": True, \"Estado\": False},\n",
        "    title=\"Desglose geográfico de la inseguridad alimentaria moderada o severa<br><sup>Animación de 2016 a 2022</sup>\",\n",
        ")\n",
        "\n",
        "fig_mapa_estados.update_geos(fitbounds=\"locations\", visible=False)\n",
        "fig_mapa_estados.update_layout(\n",
        "    margin={\"r\": 0, \"t\": 80, \"l\": 0, \"b\": 0},\n",
        "    legend=dict(\n",
        "        title_text=\"Porcentaje\",\n",
        "        orientation=\"v\",\n",
        "        yanchor=\"bottom\",\n",
        "        y=0.05,\n",
        "        xanchor=\"left\",\n",
        "        x=0.0,\n",
        "        font=dict(size=11),\n",
        "    ),\n",
        "    paper_bgcolor=\"rgba(0,0,0,0)\",\n",
        "    plot_bgcolor=\"rgba(0,0,0,0)\",\n",
        ")"
      ],
      "id": "fig_mapa_estados",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: datos_desnutricion_retraso\n",
        "#| output: false\n",
        "\n",
        "# --- Retraso en el crecimiento (indicador 2.2.1) ---\n",
        "ruta_csv = f\"{path}/2.2.1_sh_es.csv\"\n",
        "I221_raw = pd.read_csv(ruta_csv)\n",
        "retraso_nac_total = (\n",
        "    I221_raw[I221_raw[\"Periodo\"] == 2018]\n",
        "    .query(\"Entidad_federativa == 'Estados_Unidos_Mexicanos'\")\n",
        "    [\"tam_loc_sexo|Nacional\"]\n",
        "    .astype(\"float64\")\n",
        "    .item()\n",
        ")\n",
        "\n",
        "I221 = pd.read_csv(ruta_csv, usecols=[1, 2, 3, 4])\n",
        "I221_sinND = I221[~I221.astype(str).apply(lambda x: x.str.contains(\"ND\")).any(axis=1)].copy()\n",
        "I221_sinND.rename(columns={\n",
        "    \"tam_loc_sexo|Nacional\": \"Retraso en el crecimiento\",\n",
        "    \"Periodo\": \"Año\",\n",
        "    \"Entidad_federativa\": \"Estado\"\n",
        "}, inplace=True)\n",
        "I221_sinND[\"Retraso en el crecimiento\"] = pd.to_numeric(I221_sinND[\"Retraso en el crecimiento\"], errors=\"coerce\")\n",
        "I221_sinND[\"Estado\"] = I221_sinND[\"Estado\"].str.replace(\"_\", \" \")\n",
        "\n",
        "estados_interes = [\"Puebla\", \"Yucatán\", \"Chiapas\", \"Oaxaca\", \"México\"]\n",
        "retraso_5 = I221_sinND.query(\"Año == 2018 and Estado in @estados_interes\")[[\"Estado\", \"Retraso en el crecimiento\"]]\n",
        "\n",
        "# --- Desnutrición (indicador 2n.1.1) ---\n",
        "ruta_csv2 = f\"{path}/2n.1.1_sh_es.csv\"\n",
        "I2n11_raw = pd.read_csv(ruta_csv2, usecols=[1, 2, 3, 4, 7, 8])\n",
        "desnutricion_nac_total = (\n",
        "    I2n11_raw[I2n11_raw[\"Periodo\"] == 2018]\n",
        "    .query(\"Entidad_federativa == 'Estados_Unidos_Mexicanos'\")\n",
        "    [\"Menores_de_5_años-desnutrición|Nacional/Total\"]\n",
        "    .astype(\"float64\")\n",
        "    .item()\n",
        ")\n",
        "\n",
        "I2n11 = pd.read_csv(ruta_csv2, usecols=[1, 2, 3, 4])\n",
        "I2n11_sinND = I2n11[~I2n11.astype(str).apply(lambda x: x.str.contains(\"ND\")).any(axis=1)].copy()\n",
        "I2n11_sinND.rename(columns={\n",
        "    \"Menores_de_5_años-desnutrición|Nacional/Total\": \"Desnutrición\",\n",
        "    \"Periodo\": \"Año\",\n",
        "    \"Entidad_federativa\": \"Estado\"\n",
        "}, inplace=True)\n",
        "I2n11_sinND[\"Estado\"] = I2n11_sinND[\"Estado\"].str.replace(\"_\", \" \")\n",
        "I2n11_sinND[\"Desnutrición\"] = pd.to_numeric(I2n11_sinND[\"Desnutrición\"], errors=\"coerce\")\n",
        "\n",
        "desnutricion_5 = I2n11_sinND.query(\"Año == 2018 and Estado in @estados_interes\")[[\"Estado\", \"Desnutrición\"]]\n",
        "\n",
        "# --- Merge ---\n",
        "retraso_desnutricion = pd.merge(retraso_5, desnutricion_5, on=\"Estado\")\n",
        "orden_estados = [\"Puebla\", \"Yucatán\", \"Chiapas\", \"Oaxaca\", \"México\"]\n",
        "retraso_desnutricion[\"Estado\"] = pd.Categorical(retraso_desnutricion[\"Estado\"], categories=orden_estados, ordered=True)\n",
        "retraso_desnutricion = retraso_desnutricion.sort_values(\"Estado\")"
      ],
      "id": "datos_desnutricion_retraso",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig_barras_desnutricion\n",
        "#| output: false\n",
        "\n",
        "df = retraso_desnutricion.copy()\n",
        "\n",
        "fig_barras = go.Figure()\n",
        "\n",
        "fig_barras.add_trace(go.Bar(\n",
        "    x=df[\"Estado\"],\n",
        "    y=df[\"Retraso en el crecimiento\"],\n",
        "    name=\"Retraso en el crecimiento\",\n",
        "    text=df[\"Retraso en el crecimiento\"].round(1).astype(str) + \"%\",\n",
        "    textposition=\"outside\",\n",
        "    marker_color=\"#d9ae61\"\n",
        "))\n",
        "\n",
        "fig_barras.add_trace(go.Bar(\n",
        "    x=df[\"Estado\"],\n",
        "    y=df[\"Desnutrición\"],\n",
        "    name=\"Desnutrición\",\n",
        "    text=df[\"Desnutrición\"].round(1).astype(str) + \"%\",\n",
        "    textposition=\"outside\",\n",
        "    marker_color=\"#d1462f\"\n",
        "))\n",
        "\n",
        "fig_barras.add_trace(go.Scatter(\n",
        "    x=df[\"Estado\"],\n",
        "    y=[retraso_nac_total] * len(df),\n",
        "    mode=\"lines\",\n",
        "    name=f\"Nacional retraso: {retraso_nac_total:.1f}%\",\n",
        "    line=dict(dash=\"dash\", color=\"#1B4F72\", width=2)\n",
        "))\n",
        "\n",
        "fig_barras.add_trace(go.Scatter(\n",
        "    x=df[\"Estado\"],\n",
        "    y=[desnutricion_nac_total] * len(df),\n",
        "    mode=\"lines\",\n",
        "    name=f\"Nacional desnutrición: {desnutricion_nac_total:.1f}%\",\n",
        "    line=dict(dash=\"dash\", color=\"#160f29\", width=2)\n",
        "))\n",
        "\n",
        "fig_barras.update_layout(\n",
        "    title=(\n",
        "        \"<b>Presencia de desnutrición y retraso en el crecimiento en niños de 5 años</b><br>\"\n",
        "        \"<sup>Comparación estatal contra referencia nacional, 2018</sup>\"\n",
        "    ),\n",
        "    barmode=\"group\",\n",
        "    yaxis_title=\"Porcentaje (%)\",\n",
        "    xaxis_title=\"Estado\",\n",
        "    template=\"plotly_white\",\n",
        "    title_x=0.5,\n",
        "    legend_title_text=\"Indicador\",\n",
        "    legend=dict(\n",
        "        orientation=\"v\",\n",
        "        yanchor=\"top\",\n",
        "        y=1,\n",
        "        xanchor=\"right\",\n",
        "        x=1,\n",
        "    ),\n",
        "    margin=dict(t=90, b=50, l=60, r=20),\n",
        "    paper_bgcolor=\"rgba(0,0,0,0)\",\n",
        "    plot_bgcolor=\"white\",\n",
        ")\n",
        "\n",
        "fig_barras.update_yaxes(\n",
        "    range=[0, max(df[\"Retraso en el crecimiento\"].max(), df[\"Desnutrición\"].max(),\n",
        "                  retraso_nac_total, desnutricion_nac_total) * 1.3],\n",
        "    ticksuffix=\"%\"\n",
        ")"
      ],
      "id": "fig_barras_desnutricion",
      "execution_count": null,
      "outputs": []
    },
