      "source": [
        "#| label: crear-graficas\n",
        "#| output: false\n",
        "\n",
        "# ── Figura 9.3.2a: Proporción con crédito ──────────────────────────────────\n",
        "fig_932a = px.line(\n",
        "    df_932,\n",
        "    x='Periodo',\n",
        "    y='Proporcion de unidades',\n",
        "    markers=True,\n",
        "    text='Proporcion de unidades'\n",
        ")\n",
        "fig_932a.update_traces(\n",
        "    texttemplate='%{text:.1f}%',\n",
        "    textposition='top center',\n",
        "    line_color='#e15d57',\n",
        "    marker=dict(size=10)\n",
        ")\n",
        "fig_932a.update_layout(\n",
        "    xaxis_title=\"Año\",\n",
        "    yaxis_title=\"Porcentaje (%)\",\n",
        "    plot_bgcolor='white',\n",
        "    yaxis=dict(showgrid=True, gridcolor='LightGray', griddash='dot'),\n",
        "    xaxis=dict(showgrid=True, gridcolor='LightGray', griddash='dot'),\n",
        "    margin=dict(t=40, b=80, l=60, r=40),\n",
        ")\n",
        "\n",
        "# ── Figura 9.3.2b: Empresas vs. crédito ───────────────────────────────────\n",
        "fig_932b = make_subplots(specs=[[{\"secondary_y\": True}]])\n",
        "\n",
        "fig_932b.add_trace(\n",
        "    go.Bar(x=periodos, y=total_unidades, name='Total de unidades económicas',\n",
        "           marker_color='#a8c8e8', opacity=0.7, offsetgroup=0),\n",
        "    secondary_y=False\n",
        ")\n",
        "fig_932b.add_trace(\n",
        "    go.Bar(x=periodos, y=numero_unidades, name='Unidades con crédito',\n",
        "           marker_color='#1f77b4',\n",
        "           text=[f\"{v:,.0f}\" for v in numero_unidades],\n",
        "           textposition='outside',\n",
        "           textfont=dict(size=11, color='#1f77b4', weight='bold'),\n",
        "           offsetgroup=0),\n",
        "    secondary_y=False\n",
        ")\n",
        "fig_932b.add_trace(\n",
        "    go.Scatter(x=periodos, y=proporcion_unidades, name='Proporción con crédito (%)',\n",
        "               mode='lines+markers+text',\n",
        "               line=dict(color='#e15d57', width=3),\n",
        "               marker=dict(symbol='diamond', size=10, color='#e15d57'),\n",
        "               text=[f\"{v:.1f}%\" for v in proporcion_unidades],\n",
        "               textposition='top center',\n",
        "               textfont=dict(color='#282828', size=11, weight='bold')),\n",
        "    secondary_y=True\n",
        ")\n",
        "fig_932b.update_layout(\n",
        "    xaxis=dict(title='Año'),\n",
        "    yaxis=dict(title='Número de unidades económicas', showgrid=True, gridcolor='rgba(0,0,0,0.05)'),\n",
        "    yaxis2=dict(title='Proporción con crédito (%)', color='#e15d57',\n",
        "                overlaying='y', side='right', showgrid=False, range=[0, 35]),\n",
        "    barmode='overlay', plot_bgcolor='white',\n",
        "    margin=dict(t=40, b=100, l=60, r=60),\n",
        "    legend=dict(orientation=\"h\", yanchor=\"top\", y=-0.18, xanchor=\"center\", x=0.5),\n",
        ")\n",
        "\n",
        "# ── Figura 9.5.1: Gasto en I+D vs. PIB ────────────────────────────────────\n",
        "periodos_951 = df_951['Periodo'].astype(str)\n",
        "\n",
        "fig_951 = make_subplots(specs=[[{\"secondary_y\": True}]])\n",
        "\n",
        "fig_951.add_trace(\n",
        "    go.Bar(x=periodos_951, y=df_951['Gasto en investigacion'],\n",
        "           name='Gasto en I+D (millones MXN)', marker_color='#5767dc', opacity=0.85,\n",
        "           text=[f\"{v/1000:.0f}k\" for v in df_951['Gasto en investigacion']],\n",
        "           textposition='outside', textfont=dict(size=10, color='#5767dc')),\n",
        "    secondary_y=False\n",
        ")\n",
        "fig_951.add_trace(\n",
        "    go.Scatter(x=periodos_951, y=df_951['Gasto proporcional'], name='% del PIB',\n",
        "               mode='lines+markers+text',\n",
        "               line=dict(color='#e15d57', width=3), marker=dict(size=9, color='#e15d57'),\n",
        "               text=[f\"{v:.3f}%\" for v in df_951['Gasto proporcional']],\n",
        "               textposition='top center', textfont=dict(size=11, color='#282828', weight='bold')),\n",
        "    secondary_y=True\n",
        ")\n",
        "\n",
        "z = np.polyfit(range(len(df_951)), df_951['Gasto proporcional'], 1)\n",
        "tendencia = np.poly1d(z)(range(len(df_951)))\n",
        "fig_951.add_trace(\n",
        "    go.Scatter(x=periodos_951, y=tendencia, name='Tendencia % PIB', mode='lines',\n",
        "               line=dict(color='#e15d57', width=1.5, dash='dash'), opacity=0.5),\n",
        "    secondary_y=True\n",
        ")\n",
        "fig_951.update_layout(\n",
        "    xaxis=dict(title='Año', tickmode='linear'),\n",
        "    yaxis=dict(title='Millones de pesos (MXN)', showgrid=True, gridcolor='rgba(0,0,0,0.05)'),\n",
        "    yaxis2=dict(title='Proporción del PIB (%)', color='#e15d57',\n",
        "                overlaying='y', side='right', showgrid=False),\n",
        "    plot_bgcolor='white', barmode='overlay',\n",
        "    margin=dict(t=40, b=100, l=60, r=60),\n",
        "    legend=dict(orientation=\"h\", yanchor=\"top\", y=-0.18, xanchor=\"center\", x=0.5),\n",
        ")\n",
        "\n",
        "# ── Figura 9n.2.1: Estímulo vs. Multiplicador ─────────────────────────────\n",
        "fig_9n21 = make_subplots(specs=[[{\"secondary_y\": True}]])\n",
        "\n",
        "fig_9n21.add_trace(\n",
        "    go.Bar(x=periodos_9n21, y=autorizado, name='Valor proyectos autorizados',\n",
        "           marker_color='#a8c8e8', opacity=0.85, offsetgroup=1),\n",
        "    secondary_y=False\n",
        ")\n",
        "fig_9n21.add_trace(\n",
        "    go.Bar(x=periodos_9n21, y=estimulo, name='Valor estímulo fiscal',\n",
        "           marker_color='#1f77b4',\n",
        "           text=[f\"{v/1e6:.1f}M\" for v in estimulo],\n",
        "           textposition='outside', textfont=dict(size=11, color='#1f77b4', weight='bold'),\n",
        "           offsetgroup=1),\n",
        "    secondary_y=False\n",
        ")\n",
        "fig_9n21.add_trace(\n",
        "    go.Scatter(x=periodos_9n21, y=multiplicador, name='Multiplicador del subsidio',\n",
        "               mode='lines+markers+text',\n",
        "               line=dict(color='#d62728', width=3.5),\n",
        "               marker=dict(symbol='diamond', size=11, color='#d62728'),\n",
        "               text=[f\"{v:.2f}x\" for v in multiplicador],\n",
        "               textposition='top center', cliponaxis=False,\n",
        "               textfont=dict(color='#282828', size=11, weight='bold')),\n",
        "    secondary_y=True\n",
        ")\n",
        "\n",
        "z2 = np.polyfit(range(len(df_9n21)), multiplicador, 1)\n",
        "tendencia2 = np.poly1d(z2)(range(len(df_9n21)))\n",
        "fig_9n21.add_trace(\n",
        "    go.Scatter(x=periodos_9n21, y=tendencia2, name='Tendencia multiplicador', mode='lines',\n",
        "               line=dict(color='#d62728', width=1.5, dash='dash'), opacity=0.5),\n",
        "    secondary_y=True\n",
        ")\n",
        "fig_9n21.update_layout(\n",
        "    xaxis=dict(title='Año', tickmode='linear'),\n",
        "    yaxis=dict(title='Millones de pesos', showgrid=True, gridcolor='rgba(0,0,0,0.05)'),\n",
        "    yaxis2=dict(title='Multiplicador (x veces)', range=[3, 7], color='#d62728',\n",
        "                overlaying='y', side='right', showgrid=False),\n",
        "    barmode='overlay', plot_bgcolor='white',\n",
        "    margin=dict(t=40, b=100, l=60, r=60),\n",
        "    legend=dict(orientation=\"h\", yanchor=\"top\", y=-0.18, xanchor=\"center\", x=0.5),\n",
        ")"
      ],
      "id": "crear-graficas",
      "execution_count": null,
      "outputs": []
    },
