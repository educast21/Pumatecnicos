        "#| label: calculando_grafica4\n",
        "#| output: false\n",
        "\n",
        "df = pd.read_excel(path + \"/4R.6.1.A(2)_sh_es.xls\", sheet_name=0, header=None)\n",
        "df = df.iloc[6:-22]\n",
        "df.columns = df.iloc[0]\n",
        "df = df[2:]\n",
        "cols = cols = [1,\n",
        "    11,\n",
        "    17,\n",
        "    23,\n",
        "    29\n",
        "]\n",
        "df = df.iloc[:, cols]\n",
        "df = df.drop(df.index[0])\n",
        "df = df.iloc[[7,12,20],:]\n",
        "df.columns = ['Entidad', '15-17 (2024)', '18-29 (2024)', '30-59 (2024)', '60+ (2024)']\n",
        "\n",
        "for col in df.columns[1:]:\n",
        "    df[col] = pd.to_numeric(df[col], errors='coerce')\n",
        "\n",
        "def categorizar(valor):\n",
        "    if valor <= 75: return 0      # \"[0,75]\"\n",
        "    if valor <= 90: return 1      # \"(75,90]\"\n",
        "    return 2                      # \"(90,100]\"\n",
        "\n",
        "z_num = df.iloc[:, 1:].map(categorizar).values\n",
        "z_text = df.iloc[:, 1:].values\n",
        "\n",
        "colores = [\n",
        "    [0, '#d14e39'],    # 0 corresponde a [0,75]\n",
        "    [0.5, '#efd720'], # 1 corresponde a (75,90]\n",
        "    [1, '#2dc937']      # 2 corresponde a (90,100]\n",
        "]\n",
        "\n",
        "# 4. Crear el Heatmap\n",
        "fig = go.Figure(data=go.Heatmap(\n",
        "    z=z_num,\n",
        "    x=df.columns[1:],\n",
        "    y=df['Entidad'],\n",
        "    colorscale=colores,\n",
        "    showscale=True,\n",
        "    xgap=5, # Espacio horizontal entre cuadros\n",
        "    ygap=5, # Espacio vertical entre cuadros\n",
        "    colorbar=dict(\n",
        "        title=\"Rango de Porcentaje\",\n",
        "        tickvals=[0.33, 1, 1.66], # Posicionamos los nombres en la barra\n",
        "        ticktext=[\"[0,75]\", \"(75,90]\", \"(90,100]\"]\n",
        "    ),\n",
        "    hovertemplate=\"Estado: %{y}<br>Grupo: %{x}<br>Porcentaje: %{customdata:.2f}%<extra></extra>\",\n",
        "    customdata=z_text\n",
        "))\n",
        "\n",
        "fig.update_layout(\n",
        "    title='% Población indígena alfabeta por edades a 2024, en Chiapas, Guerrero y Oaxaca',\n",
        "    xaxis={'side': 'bottom'},\n",
        "    template='plotly_white',\n",
        "    legend=dict(\n",
        "        title_text=\"\",\n",
        "        orientation=\"h\",\n",
        "        entrywidth=100,\n",
        "        yanchor=\"top\",\n",
        "        y=-0.3,\n",
        "        xanchor=\"center\",\n",
        "        x=0.5\n",
        "    ),\n",
        ")\n",
        "\n",
        "fig.update_yaxes(autorange=\"reversed\")\n"
      ],
