        "#| label: Calculando_grafica2\n",
        "#| output: false\n",
        "\n",
        "df = pd.read_excel(path + \"/4R.6.1.A(2)_sh_es.xls\", sheet_name=0, header=None)\n",
        "df = df.iloc[7:-10]\n",
        "df.columns = df.iloc[0]\n",
        "df = df[2:]\n",
        "\n",
        "# Recuperar columnas (C, AG, BK, CO, DS)\n",
        "# Los índices son: 2, 32, 62, 92, 122\n",
        "df = df.iloc[:, [0,1,2, 32, 62, 92, 122]]\n",
        "df = df.drop(df.index[0])\n",
        "df.columns = [\"cvegeo\", \"Entidad\", \"2024\",\"2022\", \"2020\", \"2018\", \"2016\"]\n",
        "anios = [\"2024\", \"2022\", \"2020\", \"2018\", \"2016\"]\n",
        "df[anios] = df[anios].apply(pd.to_numeric, errors='coerce')\n",
        "\n",
        "# Usar el GeoJSON de México con sus estados\n",
        "repo_url = 'https://raw.githubusercontent.com/angelnmara/geojson/master/mexicoHigh.json'\n",
        "repo_url_municps = 'https://raw.githubusercontent.com/angelnmara/geojson/master/MunicipiosMexico.json'\n",
        "mx_states_geojson = requests.get(repo_url).json()\n",
        "\n",
        "# Cambiar los nombres del df para que coincidan con los del json\n",
        "df.iloc[4, 1] = \"Coahuila\"\n",
        "df.iloc[15,1] = \"Michoacán\"\n",
        "df.iloc[29,1] = \"Veracruz\"\n",
        "\n",
        "# Formato largo del df, preferible para series de tiempo\n",
        "df_long = df.melt(\n",
        "    id_vars=['Entidad'],\n",
        "    value_vars=['2016', '2018', '2020', '2022', '2024'],\n",
        "    var_name='Año',\n",
        "    value_name='Porcentaje'\n",
        ")\n",
        "\n",
        "# Partición del porcentaje en categorías\n",
        "df_long['Categoría'] = pd.cut(\n",
        "    df_long['Porcentaje'],\n",
        "    bins=[0, 90, 95, 100],\n",
        "    labels=[\"[0,90]\", \"(90,95]\", \"(95,100]\"],\n",
        "    include_lowest=True,\n",
        "    right=True\n",
        ")\n",
        "\n",
        "\n",
        "# Ordenamos por año para el slider\n",
        "df_long = df_long.sort_values('Año')\n",
        "df_long['Porcentaje'] = df_long['Porcentaje'].apply(lambda x: f\"{round(x,2)}%\")\n",
        "\n",
        "colores = {\n",
        "    \"(95,100]\": \"#2dc937\",\n",
        "    \"(90,95]\": \"#efd720\",\n",
        "    \"[0,90]\": \"#d14e39\"\n",
        "}\n",
        "\n",
        "fig = px.choropleth(\n",
        "    df_long,\n",
        "    geojson=mx_states_geojson,\n",
        "    locations='Entidad',\n",
        "    featureidkey='properties.name',\n",
        "    color='Categoría',             # Coloreamos por la columna de texto\n",
        "    animation_frame='Año',\n",
        "    color_discrete_map=colores,    # Forzamos los colores definidos arriba\n",
        "    hover_name='Entidad',\n",
        "    hover_data={'Porcentaje':True, 'Entidad':False} # Mostramos el número real en el hover\n",
        ")\n",
        "\n",
        "fig.update_geos(\n",
        "    fitbounds=\"locations\",\n",
        "    visible=False\n",
        ")\n",
        "\n",
        "fig.update_layout(\n",
        "    title_text='Porcentaje de población alfabeta mayor de 15 años <br><sup>Animación del 2016 al 2024</sup>',\n",
        "    margin={\"r\":0,\"t\":80,\"l\":0,\"b\":0},\n",
        "    legend=dict(\n",
        "        title_text=\"\",\n",
        "        orientation=\"h\",\n",
        "        entrywidth=100,\n",
        "        yanchor=\"top\",\n",
        "        y=-0.3,\n",
        "        xanchor=\"center\",\n",
        "        x=0.5\n",
        "    ),\n",
        ")"
      ],
      "id": "Calculando_grafica2",
      "execution_count": null,
